@model IEnumerable<teachersWorkload.Models.Subject>

<div class="container mt-4">
    <h2>Нагрузка преподавателя</h2>
    <a asp-action="Change" class="btn btn-success mb-3">Добавить предмет</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Название</th>
                <th>Группа</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.GroupNumber</td>
                    <td>
                        <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post">
                            <button type="submit" class="btn btn-sm @(item.IsOnline ? "btn-info" : "btn-secondary")">
                                @(item.IsOnline ? "Дистанционно" : "Очно")
                            </button>
                        </form>
                    </td>
                    <td>
                        <a asp-action="Change" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Редактировать</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>